---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { routeSlugFromId, sortPostsByDate } from "../lib/posts";

const blogPosts = await getCollection("blogPosts");
const projectPosts = await getCollection("projectPosts");

const allPosts = sortPostsByDate([
  ...blogPosts.map((post) => ({ ...post, section: "blog_posts" as const })),
  ...projectPosts.map((post) => ({ ...post, section: "project_posts" as const })),
]);
---

<Layout title="Archives" bodyClass="list" activePath="/archives">
  <header class="page-header">
    <div class="breadcrumbs">
      <a href="/">Home</a>
    </div>
    <h1>Archives</h1>
  </header>
  <div class="archive-year">
    {
      allPosts.map((post) => (
        <div class="archive-entry">
          <h3 class="archive-entry-title">
            <a href={`/${post.section}/${routeSlugFromId(post.id)}/`}>{post.data.title}</a>
          </h3>
          <div class="archive-meta">
            {post.data.date.toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric",
            })}
          </div>
        </div>
      ))
    }
  </div>
</Layout>
