---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/site";
---

<Layout bodyClass="list" activePath="/">
  <div class="profile">
    <div class="profile_inner">
      <img
        draggable="false"
        src={siteConfig.profile.imageUrl}
        alt={siteConfig.profile.imageAlt}
        title={siteConfig.profile.imageAlt}
        width="180"
        height="180"
      />
      <h1>{siteConfig.profile.title}</h1>
      <span set:html={siteConfig.profile.subtitle}></span>
      <div class="social-icons">
        {
          siteConfig.profile.socialLinks.map((link) => {
            const hideText = link.label === "X" || link.label === "Zhihu" || link.label === "Xiaohongshu";
            return (
              <a
                class:list={{ "icon-only": hideText }}
                href={link.href}
                target="_blank"
                rel="noopener noreferrer me"
                title={link.label}
                aria-label={link.label}
              >
                <iconify-icon icon={link.icon}></iconify-icon>
                {!hideText && <span>{link.label}</span>}
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</Layout>
